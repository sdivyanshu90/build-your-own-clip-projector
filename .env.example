CLIP_ENVIRONMENT=development
CLIP_HOST=0.0.0.0
CLIP_PORT=8080
CLIP_LOG_LEVEL=INFO
CLIP_API_KEYS=replace-with-at-least-32-random-characters
CLIP_REQUIRE_API_KEY=true
